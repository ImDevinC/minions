# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# OIDC Configuration (PocketID or any OIDC-compliant provider)
# The OIDC provider handles access control - only users the provider
# allows to authenticate will be able to access the control panel.
OIDC_ISSUER=https://your-pocketid-instance.example.com
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret

# Optional: Custom provider name displayed on the sign-in page (default: "OIDC")
OIDC_PROVIDER_NAME=PocketID

# Optional: Override OAuth scopes (default: "openid email profile")
# OIDC_SCOPES=openid email profile

# Orchestrator API
ORCHESTRATOR_URL=http://localhost:8080
INTERNAL_API_TOKEN=your-internal-api-token
