# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Discord Access Restriction (optional)
# Restrict control panel access to members of a specific Discord guild (server).
# When set, users must be a member of this guild to log in.
# NOTE: Restart required after changing these values (OAuth scopes are computed at startup).
DISCORD_ALLOWED_GUILD_ID=
# Further restrict access to users with a specific role within the guild.
# Only effective when DISCORD_ALLOWED_GUILD_ID is also set.
DISCORD_ALLOWED_ROLE_ID=

# Orchestrator API
ORCHESTRATOR_URL=http://localhost:8080
INTERNAL_API_TOKEN=your-internal-api-token
